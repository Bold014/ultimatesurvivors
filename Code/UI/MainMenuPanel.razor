@code
{
	static SoundEvent UiClick = new( "sounds/ui_click.mp3" );

	void PlayClickSound()
	{
		try { Sound.Play( UiClick ); } catch { }
	}

	enum MenuView { Main, CharacterSelect, MapSelect, Unlocks, Quests }
	MenuView _view = MenuView.Main;

	string _selectedMapId = "dark_forest";
	int    _selectedTier  = 1;

	UnlockCategory _unlockTab          = UnlockCategory.Characters;
	string         _unlockFeedback     = null;
	bool           _unlockFeedbackErr;
	float          _unlockFeedbackTimer;

	static readonly string[] QuestFilters = { "All", "Kills", "Survival", "Level", "Character", "Runs", "Weapon", "Tome", "Deaths", "No Damage", "Chests", "Projectiles" };
	string _questFilter   = "All";
	string _questFeedback = null;
	float  _questFeedbackTimer;

	bool _questNotify => QuestDefinition.All.Exists( q => PlayerProgress.CanClaimQuest( q.Id ) );

	// ── Chat ──────────────────────────────────────────────────────────────
	struct ChatEntry { public string Name; public string Text; public string ColorHex; }

	bool _chatOpen = false;
	bool _chatSubscribed = false;
	List<ChatEntry> _chatMessages = new();

	void OnChatPanelClick( PanelEvent e )
	{
		PlayClickSound();
		if ( !_chatOpen ) _chatOpen = true;
	}

	void OnMenuChatSubmit( PanelEvent e )
	{
		if ( e.Target is not TextEntry te ) return;
		var msg = te.Text?.Trim() ?? "";
		_chatOpen = false;
		if ( string.IsNullOrEmpty( msg ) ) return;

		var name = Connection.Local?.DisplayName ?? Connection.Local?.Name ?? "Player";

		// Show message immediately (optimistic), then broadcast.
		_chatMessages.Add( new ChatEntry { Name = name, Text = msg, ColorHex = "#4ae8ff" } );
		if ( _chatMessages.Count > 8 ) _chatMessages.RemoveAt( 0 );

		var chat = ChatComponent.Instance;
		if ( chat != null )
		{
			chat.CurrentInput = msg;
			chat.Submit();
		}
	}

	void OnChatMessageAdded()
	{
		var chat = ChatComponent.Instance;
		if ( chat == null || chat.Messages.Count == 0 ) return;
		var latest = chat.Messages[^1];
		// Avoid duplicating the optimistic message we already added locally.
		if ( _chatMessages.Count > 0 &&
		     _chatMessages[^1].Name == latest.PlayerName &&
		     _chatMessages[^1].Text == latest.Text )
			return;
		_chatMessages.Add( new ChatEntry
		{
			Name     = latest.PlayerName,
			Text     = latest.Text,
			ColorHex = MenuChatColor( latest.NameColor )
		} );
		if ( _chatMessages.Count > 8 ) _chatMessages.RemoveAt( 0 );
	}

	void StopPropagation( PanelEvent e ) => e.StopPropagation();

	string MenuChatColor( Color c )
	{
		int r = (int)(c.r * 255);
		int g = (int)(c.g * 255);
		int b = (int)(c.b * 255);
		return $"#{r:X2}{g:X2}{b:X2}";
	}

	protected override void OnStart()
	{
		Panel.Style.PointerEvents = PointerEvents.All;
	}

	protected override void OnDestroy()
	{
		if ( _chatSubscribed && ChatComponent.Instance != null )
			ChatComponent.Instance.OnMessageAdded -= OnChatMessageAdded;
	}

	protected override void OnUpdate()
	{
		if ( _unlockFeedback != null )
		{
			_unlockFeedbackTimer -= Time.Delta;
			if ( _unlockFeedbackTimer <= 0f ) _unlockFeedback = null;
		}
		if ( _questFeedback != null )
		{
			_questFeedbackTimer -= Time.Delta;
			if ( _questFeedbackTimer <= 0f ) _questFeedback = null;
		}

		// Subscribe to ChatComponent once it becomes available.
		if ( ChatComponent.Instance != null && !_chatSubscribed )
		{
			ChatComponent.Instance.OnMessageAdded += OnChatMessageAdded;
			_chatSubscribed = true;
		}
	}

	// ── Character Selection ───────────────────────────────────────────────
	string _selectedCharName = null;

	void OnMuteClicked()
	{
		PlayClickSound();
		MusicManager.Instance?.ToggleMute();
	}

	void OnPlayClicked()
	{
		PlayClickSound();
		// Default to the first unlocked character
		_selectedCharName = CharacterDefinition.All
			.FirstOrDefault( c => PlayerProgress.IsUnlocked( CharToUnlockId( c.Name ) ) )
			?.Name ?? "Archer";
		_view = MenuView.CharacterSelect;
	}

	static string CharToUnlockId( string name ) => name?.ToLower() switch
	{
		"archer"     => "char_archer",
		"warrior"    => "char_warrior",
		"mage"       => "char_mage",
		"knight"     => "char_knight",
		"templar"    => "char_templar",
		"druid"      => "char_druid",
		"pyromancer" => "char_pyromancer",
		_            => "char_archer"
	};

	static string WeaponDisplayName( string internalName ) => internalName switch
	{
		"MagicWand" => "Magic Wand",
		"Aura"      => "Aura Blast",
		"Axe"       => "Throwing Axe",
		"StormRod"  => "Storm Rod",
		"OrbitalShards" => "Orbital Shards",
		"EmberTrail"    => "Ember Trail",
		"Sword"         => "Sword",
		_               => internalName
	};

	void UnlockTryBuy( string id )
	{
		if ( PlayerProgress.TryUnlock( id ) )
		{
			var def = UnlockDefinition.All.Find( u => u.Id == id );
			_unlockFeedback    = $"Unlocked {def?.Name}!";
			_unlockFeedbackErr = false;
		}
		else
		{
			_unlockFeedback    = "Not enough coins!";
			_unlockFeedbackErr = true;
		}
		_unlockFeedbackTimer = 2.5f;
	}

	void QuestClaim( string id )
	{
		if ( PlayerProgress.TryClaimQuest( id ) )
		{
			var def = QuestDefinition.All.Find( q => q.Id == id );
			_questFeedback      = $"+{def?.CoinReward} coins claimed!";
			_questFeedbackTimer = 2.5f;
		}
	}

	List<QuestDefinition> GetFilteredQuests() => _questFilter switch
	{
		"Kills"     => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.TotalKills ),
		"Survival"  => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.SurviveMinutes ),
		"Level"     => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.ReachLevel ),
		"Character" => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.KillsAsCharacter ),
		"Runs"      => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.CompleteRuns ),
		"Weapon"    => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.KillsWithWeapon ),
		"Tome"      => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.TomeReachLevel ),
		"Deaths"    => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.TotalDeaths ),
		"No Damage" => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.NoDamageSeconds ),
		"Chests"      => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.ChestsPurchased ),
		"Projectiles" => QuestDefinition.All.FindAll( q => q.GoalType == QuestGoalType.ProjectilesFired ),
		_             => QuestDefinition.All
	};

