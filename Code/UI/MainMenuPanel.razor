@namespace Sandbox.UI
@using Sandbox;
@using Sandbox.UI;
@using System.Linq;
@using System.Threading.Tasks;
@inherits PanelComponent;

@{
	var unlockItems    = UnlockDefinition.ForCategory( _unlockTab );
	var filteredQuests = GetFilteredQuests();
	int totalQuests     = QuestDefinition.All.Count;
	int completedQuests = QuestDefinition.All.FindAll( q => PlayerProgress.IsQuestClaimed( q.Id ) ).Count;
}

<root style="background-image: url(ui/menu_bg.png); background-size: cover; background-position: center; @(LocalGameRunner.IsInLocalGame ? "opacity: 0; pointer-events: none;" : "")">
	@* Hide menu when in local game (prefab overlay); GameHUD from prefab is shown instead *@
	@if ( !LocalGameRunner.IsInLocalGame )
	{
	@* ══════════════════════════════════════════════════
	    MAIN PANEL  (content is a direct child of root)
	   ══════════════════════════════════════════════════ *@
	@if ( _view == MenuView.Main )
	{
		<!-- Top-right stats — coin counter -->
		<div style="position: absolute; top: 20px; right: 24px;">
			<div style="display: flex; align-items: center; gap: 8px; background-color: #120c04; border: 2px solid #6a4a1a; padding: 6px 14px; border-radius: 6px;">
				<img src="ui/coin.png" style="width: 42px; height: 42px; flex-shrink: 0;" />
				<span style="font-size: 16px; color: #f5c518; font-weight: bold;">@PlayerProgress.Data.Coins</span>
			</div>
		</div>

		<!-- Title logo -->
		<div style="position: absolute; top: 2%; left: 0; width: 100%; display: flex; justify-content: center; align-items: center;">
			<img src="ui/logo.png" style="width: 640px; max-width: 90%; height: auto;" />
		</div>

		<!-- Main menu buttons -->
		<div class="btn-wrap" style="top: 44%;" onclick=@(() => { PlayClickSound(); _view = MenuView.CharacterSelect; })>
			<div class="menu-main-btn"><span class="menu-main-btn-text">PLAY</span></div>
		</div>
		<div class="btn-wrap" style="top: 56%;" onclick=@(() => { PlayClickSound(); _view = MenuView.Unlocks; })>
			<div class="menu-main-btn"><span class="menu-main-btn-text">UNLOCKS</span></div>
		</div>
		<div class="btn-wrap" style="top: 68%;" onclick=@(() => { PlayClickSound(); _view = MenuView.Quests; })>
			<div class="menu-main-btn"><span class="menu-main-btn-text">QUESTS</span></div>
		</div>

		<!-- Version — bottom, full width -->
		<div style="position: absolute; bottom: 12px; left: 0; width: 100%; display: flex; justify-content: center; font-size: 11px; color: #334; letter-spacing: 2px; font-family: Minecraft;">
			ULTIMATE SURVIVORS v0.1
		</div>

		<!-- Mute button — bottom right -->
		<div class="mute-btn @(PlayerProgress.Data.MusicMuted ? "mute-btn-muted" : "")"
		     style="position: absolute; bottom: 12px; right: 24px;"
		     onclick=@OnMuteClicked>
			@(PlayerProgress.Data.MusicMuted ? "🔇" : "🔊")
		</div>

		<!-- Active Quests — top left -->
		<div class="widget-panel" style="position: absolute; top: 16px; left: 16px; width: 460px;">
			<div class="widget-header">⚔ ACTIVE QUESTS</div>
			@{
				var activeQuests = QuestDefinition.All
					.Where( q => !PlayerProgress.IsQuestClaimed( q.Id ) && PlayerProgress.GetQuestProgress( q.Id ) > 0 )
					.OrderByDescending( q => (float)PlayerProgress.GetQuestProgress( q.Id ) / q.Target )
					.Take( 4 )
					.ToList();
			}
			@if ( activeQuests.Count == 0 )
			{
				<div style="font-size: 14px; color: #888; font-family: Minecraft; padding: 8px 0;">No active quests yet</div>
			}
			@foreach ( var q in activeQuests )
			{
			var prog     = PlayerProgress.GetQuestProgress( q.Id );
			var pct      = (int)System.Math.Min( 100, (float)prog / q.Target * 100 );
			var canClaim = PlayerProgress.CanClaimQuest( q.Id );
			var icon     = QuestIcon( q.GoalType );
			var qCharName = q.GoalType == QuestGoalType.KillsAsCharacter ? (UnlockDefinition.All.Find( u => u.Id == q.CharacterId )?.Name ?? "") : "";
			<div class="quest-entry @(canClaim ? "quest-entry-claim" : "")">
				<div style="display: flex; align-items: center; gap: 10px;">
				@if ( q.GoalType == QuestGoalType.KillsAsCharacter )
				{
					<div style="width: 36px; height: 36px; flex-shrink: 0; background-color: @CharColor(qCharName); border: 2px solid @(canClaim ? "#c8a800" : "#6a4a1a"); border-radius: 4px; display: flex; align-items: center; justify-content: center;">
						<img src="@CharIconPath(qCharName)" style="width: 28px; height: 28px; image-rendering: pixelated;" />
					</div>
				}
				else if ( QuestIconImg( q.GoalType ) is {} qImgPath )
				{
					<div style="width: 36px; height: 36px; flex-shrink: 0; background-color: @(canClaim ? "#2a2200" : "#1a1008"); border: 2px solid @(canClaim ? "#c8a800" : "#6a4a1a"); border-radius: 4px; display: flex; align-items: center; justify-content: center;">
						<img src="@qImgPath" style="width: 26px; height: 26px;" />
					</div>
				}
				else
				{
					<div style="width: 36px; height: 36px; flex-shrink: 0; background-color: @(canClaim ? "#2a2200" : "#1a1008"); border: 2px solid @(canClaim ? "#c8a800" : "#6a4a1a"); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 18px;">@icon</div>
				}
						<div style="flex: 1;">
							<div style="font-size: 14px; font-weight: bold; color: @(canClaim ? "#f5c518" : "#eee"); font-family: Minecraft; text-shadow: 1px 1px 0 #000; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@q.Description</div>
							<div style="display: flex; align-items: center; gap: 8px; margin-top: 6px;">
								<div style="flex: 1; background-color: #120c04; height: 10px; border-radius: 4px; border: 1px solid #5a3a10;">
									<div style="background-color: @(canClaim ? "#c8a800" : "#8a5a20"); height: 100%; width: @pct%; border-radius: 4px;"></div>
								</div>
								<span style="font-size: 12px; color: @(canClaim ? "#f5c518" : "#aaa"); font-family: Minecraft; font-weight: bold; flex-shrink: 0;">@prog / @q.Target</span>
							</div>
							@if ( canClaim )
							{
								<div style="display: flex; align-items: center; justify-content: space-between; margin-top: 6px;">
									<span style="font-size: 11px; color: #f5c518; font-weight: bold; font-family: Minecraft; letter-spacing: 2px; white-space: nowrap;">✓ COMPLETED</span>
									<div class="claim-btn" onclick=@(() => { PlayClickSound(); QuestClaim( q.Id ); })>CLAIM</div>
								</div>
							}
						</div>
					</div>
				</div>
			}
		</div>

		<!-- Chat — left of main buttons -->
		<div class="widget-panel" style="position: absolute; top: 42%; left: 5%; width: 420px; pointer-events: all; cursor: @(_chatOpen ? "default" : "pointer");"
			onclick=@OnChatPanelClick>
			<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2px;">
				<div class="widget-header" style="border-bottom: none; padding-bottom: 0; margin-bottom: 0;">💬 CHAT</div>
				<div style="display: flex; align-items: center; gap: 5px;">
					<div style="width: 7px; height: 7px; border-radius: 50%; background-color: #4cff6e; box-shadow: 0 0 5px #4cff6e;"></div>
					<span style="font-size: 11px; color: #4cff6e; font-family: Minecraft; font-weight: bold; letter-spacing: 1px;">@_onlineCount ONLINE</span>
				</div>
			</div>
			<div style="height: 2px; background-color: #6a4a1a; margin-bottom: 10px;"></div>
			<div style="min-height: 250px; display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px;">
				@foreach ( var msg in _chatMessages )
				{
					var isServer = msg.Name == "Server";
					<div style="font-size: 13px; font-family: Minecraft; padding: 3px 6px; border-bottom: 1px solid #3a2510; background: @(isServer ? "#1a0f0a" : "transparent"); border-radius: @(isServer ? "4px" : "0");">
						@if ( isServer )
						{
							<span style="color: @msg.ColorHex; font-weight: bold;">@msg.Text</span>
						}
						else
						{
							<span style="color: @msg.ColorHex; font-weight: bold;">@msg.Name</span>
							<span style="color: #ccc;">: @msg.Text</span>
						}
					</div>
				}
			</div>
			@if ( _chatOpen )
			{
				<div style="border: 2px solid #6a4a1a; border-radius: 4px; padding: 6px 10px; pointer-events: all;" onclick=@StopPropagation>
					<TextEntry style="color: #fff; font-size: 13px; font-family: Minecraft; width: 100%;"
						placeholder="Type a message and press Enter..."
						onsubmit=@OnMenuChatSubmit />
				</div>
			}
			else
			{
				<div style="font-size: 12px; color: #a08050; font-family: Minecraft; padding: 9px 4px;">Click to chat</div>
			}
		</div>

		<!-- Leaderboard — three-column, centered right -->
		<div class="widget-panel" style="position: absolute; top: 50%; transform: translateY(-50%); right: 2%; width: 560px;">
			<div style="display: flex; flex-direction: row; align-items: center; justify-content: space-between; margin-bottom: 0;">
				<div class="widget-header" style="border-bottom: none; padding-bottom: 0; margin-bottom: 0;">🏆 LEADERBOARD</div>
				@{
					var canRefresh = !_lbLoading && _lbRefreshCooldown <= 0f;
					var refreshLabel = _lbLoading ? "..." : _lbRefreshCooldown > 0f ? $"({(int)System.Math.Ceiling(_lbRefreshCooldown)}s)" : "↻";
				}
				<div onclick="@(() => { if ( canRefresh ) { PlayClickSound(); _lbRefreshCooldown = 5f; _lbRefreshTimer = 60f; _ = RefreshLeaderboardAsync(); } })"
				     style="font-size: 16px; font-family: Minecraft; color: @(canRefresh ? "#f5c518" : "#555"); cursor: @(canRefresh ? "pointer" : "default"); padding: 2px 8px; border: 1px solid @(canRefresh ? "#6a4a1a" : "#2a1a08"); border-radius: 4px; font-weight: bold;">@refreshLabel</div>
			</div>
			<div style="height: 2px; background-color: #6a4a1a; margin-bottom: 10px;"></div>
			<div style="display: flex; flex-direction: row; gap: 0;">

				<!-- Kills column -->
				<div style="flex: 1; display: flex; flex-direction: column; padding: 0 8px;">
					<div style="font-size: 11px; color: #a08050; font-family: Minecraft; font-weight: bold; letter-spacing: 1px; text-align: center; padding-bottom: 6px; border-bottom: 1px solid #6a4a1a; margin-bottom: 4px; white-space: nowrap;">⚔ KILLS</div>
					@if ( _lbLoading )
					{
						<div style="font-size: 11px; color: #555; font-family: Minecraft; padding: 8px 0; text-align: center; font-style: italic;">Loading...</div>
					}
					else if ( _lbError )
					{
						<div style="font-size: 11px; color: #a55; font-family: Minecraft; padding: 8px 0; text-align: center;">Error</div>
					}
					@foreach ( var entry in _lbKills )
					{
						var isLocal   = Connection.Local != null && entry.SteamId == Connection.Local.SteamId;
						var rankColor = entry.Rank == 1 ? "#f5c518" : entry.Rank == 2 ? "#c0c0c0" : entry.Rank == 3 ? "#cd7f32" : "#aaa";
						<div style="display: flex; flex-direction: row; align-items: center; padding: 5px 2px; border-bottom: 1px solid #2a1a08; gap: 4px; flex-shrink: 0;">
							<span style="font-size: 11px; font-weight: bold; color: @rankColor; font-family: Minecraft; width: 18px; flex-shrink: 0;">#@entry.Rank</span>
							<img src="avatar:@entry.SteamId" style="width: 20px; height: 20px; border-radius: 3px; border: 1px solid @(isLocal ? "#f5c518" : "#5a3a10"); flex-shrink: 0;" />
							<span style="font-size: 11px; color: @(isLocal ? "#f5e060" : "#ddd"); font-family: Minecraft; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@entry.DisplayName</span>
							<span style="font-size: 11px; color: #f5c518; font-family: Minecraft; font-weight: bold; flex-shrink: 0;">@LbFormatKills( entry.Value )</span>
						</div>
					}
					@for ( int i = _lbKills.Count; i < 10; i++ )
					{
						<div style="display: flex; flex-direction: row; align-items: center; padding: 5px 2px; border-bottom: 1px solid #1a1008; gap: 4px; opacity: 0.2; flex-shrink: 0;">
							<span style="font-size: 11px; font-weight: bold; color: #666; font-family: Minecraft; width: 18px; flex-shrink: 0;">#@(i+1)</span>
							<div style="width: 20px; height: 20px; border-radius: 3px; background-color: #1a1008; flex-shrink: 0;"></div>
							<span style="font-size: 11px; color: #444; font-family: Minecraft; flex: 1;">---</span>
						</div>
					}
				</div>

				<div style="width: 1px; background-color: #3a2510; flex-shrink: 0;"></div>

				<!-- Survival column -->
				<div style="flex: 1; display: flex; flex-direction: column; padding: 0 8px;">
					<div style="font-size: 11px; color: #a08050; font-family: Minecraft; font-weight: bold; letter-spacing: 1px; text-align: center; padding-bottom: 6px; border-bottom: 1px solid #6a4a1a; margin-bottom: 4px; white-space: nowrap;">⏱ SURVIVAL</div>
					@if ( _lbLoading )
					{
						<div style="font-size: 11px; color: #555; font-family: Minecraft; padding: 8px 0; text-align: center; font-style: italic;">Loading...</div>
					}
					else if ( _lbError )
					{
						<div style="font-size: 11px; color: #a55; font-family: Minecraft; padding: 8px 0; text-align: center;">Error</div>
					}
					@foreach ( var entry in _lbSurvival )
					{
						var isLocal   = Connection.Local != null && entry.SteamId == Connection.Local.SteamId;
						var rankColor = entry.Rank == 1 ? "#f5c518" : entry.Rank == 2 ? "#c0c0c0" : entry.Rank == 3 ? "#cd7f32" : "#aaa";
						<div style="display: flex; flex-direction: row; align-items: center; padding: 5px 2px; border-bottom: 1px solid #2a1a08; gap: 4px; flex-shrink: 0;">
							<span style="font-size: 11px; font-weight: bold; color: @rankColor; font-family: Minecraft; width: 18px; flex-shrink: 0;">#@entry.Rank</span>
							<img src="avatar:@entry.SteamId" style="width: 20px; height: 20px; border-radius: 3px; border: 1px solid @(isLocal ? "#f5c518" : "#5a3a10"); flex-shrink: 0;" />
							<span style="font-size: 11px; color: @(isLocal ? "#f5e060" : "#ddd"); font-family: Minecraft; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@entry.DisplayName</span>
							<span style="font-size: 11px; color: #f5c518; font-family: Minecraft; font-weight: bold; flex-shrink: 0;">@entry.Value m</span>
						</div>
					}
					@for ( int i = _lbSurvival.Count; i < 10; i++ )
					{
						<div style="display: flex; flex-direction: row; align-items: center; padding: 5px 2px; border-bottom: 1px solid #1a1008; gap: 4px; opacity: 0.2; flex-shrink: 0;">
							<span style="font-size: 11px; font-weight: bold; color: #666; font-family: Minecraft; width: 18px; flex-shrink: 0;">#@(i+1)</span>
							<div style="width: 20px; height: 20px; border-radius: 3px; background-color: #1a1008; flex-shrink: 0;"></div>
							<span style="font-size: 11px; color: #444; font-family: Minecraft; flex: 1;">---</span>
						</div>
					}
				</div>

				<div style="width: 1px; background-color: #3a2510; flex-shrink: 0;"></div>

				<!-- Runs column -->
				<div style="flex: 1; display: flex; flex-direction: column; padding: 0 8px;">
					<div style="font-size: 11px; color: #a08050; font-family: Minecraft; font-weight: bold; letter-spacing: 1px; text-align: center; padding-bottom: 6px; border-bottom: 1px solid #6a4a1a; margin-bottom: 4px; white-space: nowrap;">🔄 RUNS</div>
					@if ( _lbLoading )
					{
						<div style="font-size: 11px; color: #555; font-family: Minecraft; padding: 8px 0; text-align: center; font-style: italic;">Loading...</div>
					}
					else if ( _lbError )
					{
						<div style="font-size: 11px; color: #a55; font-family: Minecraft; padding: 8px 0; text-align: center;">Error</div>
					}
					@foreach ( var entry in _lbRuns )
					{
						var isLocal   = Connection.Local != null && entry.SteamId == Connection.Local.SteamId;
						var rankColor = entry.Rank == 1 ? "#f5c518" : entry.Rank == 2 ? "#c0c0c0" : entry.Rank == 3 ? "#cd7f32" : "#aaa";
						<div style="display: flex; flex-direction: row; align-items: center; padding: 5px 2px; border-bottom: 1px solid #2a1a08; gap: 4px; flex-shrink: 0;">
							<span style="font-size: 11px; font-weight: bold; color: @rankColor; font-family: Minecraft; width: 18px; flex-shrink: 0;">#@entry.Rank</span>
							<img src="avatar:@entry.SteamId" style="width: 20px; height: 20px; border-radius: 3px; border: 1px solid @(isLocal ? "#f5c518" : "#5a3a10"); flex-shrink: 0;" />
							<span style="font-size: 11px; color: @(isLocal ? "#f5e060" : "#ddd"); font-family: Minecraft; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@entry.DisplayName</span>
							<span style="font-size: 11px; color: #f5c518; font-family: Minecraft; font-weight: bold; flex-shrink: 0;">@entry.Value</span>
						</div>
					}
					@for ( int i = _lbRuns.Count; i < 10; i++ )
					{
						<div style="display: flex; flex-direction: row; align-items: center; padding: 5px 2px; border-bottom: 1px solid #1a1008; gap: 4px; opacity: 0.2; flex-shrink: 0;">
							<span style="font-size: 11px; font-weight: bold; color: #666; font-family: Minecraft; width: 18px; flex-shrink: 0;">#@(i+1)</span>
							<div style="width: 20px; height: 20px; border-radius: 3px; background-color: #1a1008; flex-shrink: 0;"></div>
							<span style="font-size: 11px; color: #444; font-family: Minecraft; flex: 1;">---</span>
						</div>
					}
				</div>

			</div>
		</div>
	}

	@* ══════════════════════════════════════════════════
	    CHARACTER SELECT PANEL
	   ══════════════════════════════════════════════════ *@
	else if ( _view == MenuView.CharacterSelect )
	{
		@{
			var selDef     = CharacterDefinition.GetByName( _selectedCharName ?? "Archer" );
			var selUnlocked = PlayerProgress.IsUnlocked( CharToUnlockId( selDef.Name ) );
			var selUnlockDef = UnlockDefinition.All.Find( u => u.Id == CharToUnlockId( selDef.Name ) );
			var confirmLabel = selDef.Name.ToUpper();
		}
		<!-- Dim overlay — also serves as flex centering container -->
		<div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.65); display: flex; align-items: center; justify-content: center;">
		<!-- Main panel — fixed width, auto-height, centered by parent flex -->
		<div style="width: 820px; display: flex; flex-direction: column; font-family: Minecraft; background-color: #1a1008; border: 3px solid #6a4a1a; border-radius: 10px; overflow: hidden;">

			<!-- Header -->
			<div style="padding: 18px 28px 16px 28px; flex-shrink: 0; border-bottom: 2px solid #6a4a1a; display: flex; align-items: center; justify-content: space-between;">
				<div>
					<div style="font-size: 30px; font-weight: 900; color: #f5c518; letter-spacing: 4px; text-shadow: 2px 2px 0 #000;">CHARACTER SELECTION</div>
					<div style="font-size: 12px; color: #a08050; letter-spacing: 2px; margin-top: 4px;">Choose your hero for this run</div>
				</div>
				<div class="back-btn" onclick=@(() => { PlayClickSound(); _view = MenuView.Main; })>← BACK</div>
			</div>

			<!-- Two-column body — height driven by content, not by panel stretch -->
			<div style="display: flex; flex-direction: row; align-items: flex-start;">

				<!-- LEFT: icon grid — explicit rows of 2, each cell flex:1 to fill row -->
				<div style="width: 210px; flex-shrink: 0; border-right: 2px solid #3a2510; padding: 14px 10px; display: flex; flex-direction: column; gap: 10px;">
					<div style="font-size: 11px; color: #a08050; letter-spacing: 2px;">SELECT HERO</div>
					@{
						var allChars = CharacterDefinition.All;
						for ( int _row = 0; _row < allChars.Count; _row += 2 )
						{
							<div style="display: flex; flex-direction: row; gap: 8px;">
							@for ( int _col = _row; _col < System.Math.Min( _row + 2, allChars.Count ); _col++ )
							{
								var charDef    = allChars[_col];
								var unlockId   = CharToUnlockId( charDef.Name );
								var isUnlocked = PlayerProgress.IsUnlocked( unlockId );
								var isSelected = _selectedCharName == charDef.Name;
								<div class="portrait-cell @(isSelected ? "portrait-cell-selected" : (isUnlocked ? "" : "portrait-cell-locked"))"
								     onclick=@(() => { PlayClickSound(); _selectedCharName = charDef.Name; })>
								<div style="width: 72px; height: 72px; border-radius: 5px; background-color: @CharColor(charDef.Name); display: flex; align-items: center; justify-content: center;">
									<img src="@CharIconPath( charDef.Name )" style="width: 56px; height: 56px; image-rendering: pixelated;" />
								</div>
									<div style="font-size: 10px; font-weight: bold; color: @(isSelected ? "#f5c518" : (isUnlocked ? "#ccc" : "#666")); text-align: center; margin-top: 4px; letter-spacing: 1px;">
										@charDef.Name.ToUpper()
									</div>
								</div>
							}
							</div>
						}
					}
				</div>

			<!-- RIGHT: detail panel -->
			<div style="flex: 1; padding: 24px 32px; display: flex; flex-direction: column; gap: 20px; overflow: visible;">

		<!-- Portrait row: icon + name side by side -->
			<div style="display: flex; flex-direction: row; align-items: center; gap: 18px; flex-shrink: 0; overflow: visible;">
					<div style="width: 90px; height: 90px; flex-shrink: 0; border-radius: 10px; background-color: @CharColor(selDef.Name); border: 3px solid @(selUnlocked ? "#f5c518" : "#5a3a10"); display: flex; align-items: center; justify-content: center; font-size: 42px;">
						@if ( selUnlocked )
						{
							<img src="@CharIconPath( selDef.Name )" style="width: 70px; height: 70px; image-rendering: pixelated;" />
						}
						else
						{
							<img src="ui/locked.png" style="width: 48px; height: 48px; image-rendering: pixelated;" />
						}
					</div>
						<div style="font-size: 28px; font-weight: 900; color: @(selUnlocked ? "#f5c518" : "#666"); letter-spacing: 2px; text-shadow: 2px 2px 0 #000;">@selDef.Name.ToUpper()</div>
					</div>
				<!-- Description — full width below portrait row -->
