	// ── Thumbnail icon paths (same as inventory/unlock page) ───────────────────

	static string WeaponIconPath( string weaponNameOrId )
	{
		var key = (weaponNameOrId ?? "").ToLowerInvariant()
			.Replace( " ", "" ).Replace( "throwing", "" );
		if ( key.StartsWith( "weapon_" ) ) key = key[7..];
		return key switch
		{
			"magicwand" => "ui/weapons/magicwand.png",
			"bow" => "ui/weapons/bow.png",
			"axe" => "ui/weapons/axe.png",
			"aura" or "aurablast" => "ui/weapons/aura.png",
			"stormrod" => "ui/weapons/stormrod.png",
			"orbitalshards" => "ui/weapons/orbitalshards.png",
			"embertrail" => "ui/weapons/embertrail.png",
			"sword" => "ui/weapons/sword.png",
			_ => null
		};
	}

	static (string path, bool isDirect) GetIconInfo( UpgradeDefinition upgrade, bool isWeapon )
	{
		if ( isWeapon )
			return (WeaponIconPath( upgrade.WeaponName ), false);

		// Unlockable items — custom pixel icons (direct image)
		if ( upgrade.UnlockId?.StartsWith( "item_" ) == true )
		{
			var p = ItemIconPath( upgrade.UnlockId );
			if ( p != null ) return (p, true);
		}

		// Base chest items — map by name to custom icons (direct) or thematic tome icons (sprite sheet)
		var directPath = BaseChestItemDirectIcon( upgrade.Name );
		if ( directPath != null ) return (directPath, true);

		var tomePath = BaseChestItemTomeIcon( upgrade.Name );
		if ( tomePath != null ) return (tomePath, false);

		// Tomes
		return (TomeIconPath( upgrade.Name ), false);
	}

	static string ItemIconPath( string itemId )
	{
		return itemId switch
		{
			"item_revival"       => "ui/items/revivalstone.png",
			"item_luckcharm"     => "ui/items/luckcharm.png",
			"item_pendant"       => "ui/items/wardingpendant.png",
			"item_ironrations"   => "ui/items/ironrations.png",
			"item_cursedamulet"  => "ui/items/cursedamulet.png",
			"item_merchantbadge" => "ui/items/merchantbadge.png",
			_                    => null
		};
	}

	// Base chest items that share a custom pixel icon
	static string BaseChestItemDirectIcon( string name ) => name switch
	{
		"Lucky Charm"         => "ui/items/luckcharm.png",
		"Fortune Crystal"     => "ui/items/luckcharm.png",
		"Resurrection Charm"  => "ui/items/revivalstone.png",
		"Iron Skin"           => "ui/items/wardingpendant.png",
		"Vampiric Charm"      => "ui/items/cursedamulet.png",
		_                     => null
	};

	// Base chest items mapped to thematic tome sprite sheets
	static string BaseChestItemTomeIcon( string name ) => name switch
	{
		"Berserker Brew"      => "ui/tomes/damage.png",
