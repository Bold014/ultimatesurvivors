@using Sandbox;
@using System.Linq;
@inherits PanelComponent;

<root>
	@if ( IsVisible )
	{
		var sys    = UpgSys;
		var source = sys?.CurrentSource ?? UpgradeSystem.RewardSource.LevelUp;
		var state  = PlayerLocalState.LocalInstance;
		var weapons = PlayerWeapons.LocalInstance;
		var passives = PlayerPassives.LocalInstance;
		var tomes = PlayerTomes.LocalInstance;

		<!-- Full-screen overlay -->
		<div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: #0d0905ee; display: flex; align-items: center; justify-content: center; pointer-events: all; z-index: 1000; overflow: hidden;">

			<!-- ── Starburst rays ────────────────────────────────────────────── -->
			<div class="upgrade-rays"></div>

			<!-- ── Gem particles ─────────────────────────────────────────────── -->
			@if ( source == UpgradeSystem.RewardSource.LevelUp )
			{
				@foreach ( var p in Particles )
				{
					<img src="ui/weapons/xp.png" style="@GemStyle(p)" />
				}
			}

			<!-- ── Outer row: left | center | right ──────────────────────────── -->
			<div style="display: flex; flex-direction: row; align-items: flex-start; justify-content: center; gap: 20px; width: 100%; padding: 0 24px; position: relative; z-index: 1;">

				<!-- ══ LEFT PANEL: Inventory ══════════════════════════════════ -->
				<div class="upgrade-side-panel">
					<div class="upgrade-panel-header">INVENTORY</div>

					<!-- Weapons -->
					<div class="upgrade-section-label">WEAPONS</div>
					<div class="upgrade-icon-grid">
						@foreach ( var w in weapons?.Weapons ?? Array.Empty<WeaponBase>() )
						{
							var wIcon = WeaponIconPath( w.WeaponDisplayName );
							<div class="upgrade-icon-slot" style="border-color: #c8a800;">
								@if ( wIcon != null )
								{
									<div style="width: 40px; height: 40px; background-image: url('@wIcon'); background-size: contain; background-position: center; background-repeat: no-repeat; image-rendering: pixelated;"></div>
								}
								<div class="upgrade-icon-level">@w.WeaponLevel</div>
							</div>
						}
						@if ( !(weapons?.Weapons?.Any() ?? false) )
						{
							<div style="font-size: 10px; color: #5a3a10; font-family: Minecraft; text-shadow: 1px 1px 0 #000;">None</div>
						}
					</div>

					<!-- Tomes -->
					<div class="upgrade-section-label">TOMES</div>
					<div class="upgrade-icon-grid">
						@foreach ( var tomeName in passives?.Passives ?? Array.Empty<string>() )
						{
							var tIcon = TomeIconPath( tomeName );
							var tLvl = tomes?.GetLevel( tomeName ) ?? 1;
							<div class="upgrade-icon-slot" style="border-color: #8855cc;">
								@if ( tIcon != null )
								{
									<div style="width: 40px; height: 40px; background-image: url('@tIcon'); background-size: contain; background-position: center; background-repeat: no-repeat; image-rendering: pixelated;"></div>
								}
								<div class="upgrade-icon-level">@tLvl</div>
							</div>
						}
						@if ( !(passives?.Passives?.Any() ?? false) )
						{
							<div style="font-size: 10px; color: #5a3a10; font-family: Minecraft; text-shadow: 1px 1px 0 #000;">None</div>
						}
					</div>

					<!-- Items -->
					<div class="upgrade-section-label">ITEMS</div>
					<div class="upgrade-icon-grid">
						@{ var acquiredItems = state?.AcquiredItemIds ?? new List<string>(); }
						@foreach ( var itemId in acquiredItems )
						{
							var iIcon = ItemIconPath( itemId );
							<div class="upgrade-icon-slot" style="border-color: #7755cc;">
								@if ( iIcon != null )
								{
									<img src="@iIcon" style="width: 40px; height: 40px; object-fit: contain; image-rendering: pixelated;" />
								}
							</div>
						}
						@if ( !acquiredItems.Any() )
						{
							<div style="font-size: 10px; color: #5a3a10; font-family: Minecraft; text-shadow: 1px 1px 0 #000;">None</div>
						}
					</div>
				</div>

				<!-- ══ CENTER COLUMN: Title + Cards + Button ══════════════════ -->
				<div style="display: flex; flex-direction: column; align-items: center; gap: 24px; flex: 1; max-width: 700px;">

					<!-- ── Title block ──────────────────────────────────────── -->
					<div style="background: @TitleBg(source); border: 2px solid @TitleBorder(source); border-radius: 4px; padding: 12px 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; box-shadow: 0 0 0 1px rgba(0,0,0,0.3);">
						<div style="font-size: 36px; font-weight: bold; color: @TitleColor(source); font-family: Minecraft; letter-spacing: 5px; text-shadow: 2px 2px 0 #000;">@TitleText(source)</div>
						<div style="font-size: 12px; color: #a08050; font-family: Minecraft; letter-spacing: 3px; text-shadow: 1px 1px 0 #000;">@SubtitleText(source)</div>
					</div>

					<!-- ── Cards row ────────────────────────────────────────── -->
					<div style="display: flex; gap: 16px; justify-content: center;">
						@for ( int i = 0; i < (sys?.CurrentChoices?.Count ?? 0); i++ )
						{
							var upgrade = sys.CurrentChoices[i];
							var idx     = i;
							var isWeapon  = upgrade.Type == UpgradeDefinition.UpgradeType.WeaponUnlock
							             || upgrade.Type == UpgradeDefinition.UpgradeType.WeaponLevelUp;
							bool usesRarity = source == UpgradeSystem.RewardSource.Shrine
							               || ( source == UpgradeSystem.RewardSource.LevelUp
							                    && ( upgrade.MaxLevel > 0
							                      || upgrade.Type == UpgradeDefinition.UpgradeType.WeaponLevelUp ) );

							var inBanishMode = sys?.IsBanishMode ?? false;
							var cardBorder = inBanishMode ? "#ff4444"
							               : usesRarity ? RarityBorderColor( upgrade.Rarity )
							               : ( isWeapon ? "#c8a800" : "#6a4a1a" );
							var cardBg = usesRarity ? RarityBg( upgrade.Rarity )
							           : ( isWeapon ? "#1a1400" : "#1a1008" );

						<div style="width: 200px; background: @cardBg; border: 2px solid @cardBorder; border-radius: 4px; padding: 16px 14px 20px 14px; display: flex; flex-direction: column; gap: 10px; pointer-events: all; cursor: pointer; box-shadow: 0 0 0 1px rgba(0,0,0,0.2);"
							 onclick=@(() => SelectUpgrade( idx ))>

						@* ── Thumbnail (weapons, tomes & items) ── *@
						@{
							var (iconPath, iconIsDirect) = GetIconInfo( upgrade, isWeapon );
						}
						@if ( iconPath != null )
						{
							<div style="width: 96px; height: 96px; align-self: center; background: #0d0805; border: 1px solid @cardBorder; border-radius: 4px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
								@if ( iconIsDirect )
								{
									<img src="@iconPath" style="width: 80px; height: 80px; object-fit: contain; image-rendering: pixelated;" />
								}
								else
								{
									<div style="width: 80px; height: 80px; background-image: url('@iconPath'); background-size: contain; background-position: center; background-repeat: no-repeat; image-rendering: pixelated;"></div>
								}
							</div>
						}

							@* ── Rarity / type badge ── *@
							@if ( source == UpgradeSystem.RewardSource.Shrine )
							{
								<div style="background: @RarityBadgeBg(upgrade.Rarity); border: 1px solid @RarityBorderColor(upgrade.Rarity); border-radius: 2px; padding: 2px 8px; align-self: flex-start; font-size: 11px; font-family: Minecraft; color: @RarityTextColor(upgrade.Rarity); font-weight: bold; letter-spacing: 1px; text-shadow: 1px 1px 0 #000;">
									@upgrade.Rarity.ToString().ToUpper()
								</div>
							}
							else if ( isWeapon && upgrade.IsNewWeapon )
							{
								<div style="background: #1a2008; border: 1px solid #5a8a2a; border-radius: 2px; padding: 2px 8px; align-self: flex-start; font-size: 11px; font-family: Minecraft; color: #88ee88; font-weight: bold; letter-spacing: 1px; text-shadow: 1px 1px 0 #000;">
									NEW WEAPON
								</div>
							}
						else if ( isWeapon && !upgrade.IsNewWeapon )
						{
							@{
								var wpnRarityLabel = upgrade.Rarity.ToString().ToUpper();
								var wpnLevelLabel  = $"WPN {upgrade.NextLevel - 1} > {upgrade.NextLevel} / {WeaponBase.MaxWeaponLevel}";
							}
							<div style="background: @RarityBadgeBg(upgrade.Rarity); border: 1px solid @RarityBorderColor(upgrade.Rarity); border-radius: 2px; padding: 3px 8px; align-self: flex-start; display: flex; flex-direction: column; gap: 1px;">
								<span style="font-size: 11px; font-family: Minecraft; color: @RarityTextColor(upgrade.Rarity); font-weight: bold; letter-spacing: 1px; text-shadow: 1px 1px 0 #000;">@wpnRarityLabel</span>
								<span style="font-size: 10px; font-family: Minecraft; color: @RarityTextColor(upgrade.Rarity); letter-spacing: 0px; text-shadow: 1px 1px 0 #000; opacity: 0.8;">@wpnLevelLabel</span>
							</div>
						}
							else if ( source == UpgradeSystem.RewardSource.Chest )
							{
								<div style="background: #0d0d20; border: 1px solid #7755cc; border-radius: 2px; padding: 2px 8px; align-self: flex-start; font-size: 11px; font-family: Minecraft; color: #aa88ff; font-weight: bold; letter-spacing: 1px; text-shadow: 1px 1px 0 #000;">
									ITEM
								</div>
							}
							else if ( upgrade.MaxLevel > 0 )
							{
								var prevLevel = upgrade.NextLevel - 1;
								@{
									var tomeRarityLabel = upgrade.Rarity.ToString().ToUpper();
									var tomeLevelLabel  = $"TOME {prevLevel} > {upgrade.NextLevel} / {upgrade.MaxLevel}";
								}
								<div style="background: @RarityBadgeBg(upgrade.Rarity); border: 1px solid @RarityBorderColor(upgrade.Rarity); border-radius: 2px; padding: 3px 8px; align-self: flex-start; display: flex; flex-direction: column; gap: 1px;">
									<span style="font-size: 11px; font-family: Minecraft; color: @RarityTextColor(upgrade.Rarity); font-weight: bold; letter-spacing: 1px; text-shadow: 1px 1px 0 #000;">@tomeRarityLabel</span>
									<span style="font-size: 10px; font-family: Minecraft; color: @RarityTextColor(upgrade.Rarity); letter-spacing: 0px; text-shadow: 1px 1px 0 #000; opacity: 0.8;">@tomeLevelLabel</span>
								</div>
							}
							else
							{
								<div style="background: #100820; border: 1px solid #8855cc; border-radius: 2px; padding: 2px 8px; align-self: flex-start; font-size: 11px; font-family: Minecraft; color: #cc99ff; font-weight: bold; letter-spacing: 1px; text-shadow: 1px 1px 0 #000;">
									TOME
								</div>
							}

							@* ── Upgrade name ── *@
							<div style="font-size: 17px; color: #f0e0b0; font-family: Minecraft; font-weight: bold; padding-bottom: 2px; text-shadow: 1px 1px 0 #000;">
								@upgrade.Name
							</div>

							@* ── Divider ── *@
							<div style="height: 1px; background: #3a2510;"></div>

							@* ── Description ── *@
							<div style="font-size: 12px; color: #c8b090; font-family: Minecraft; padding-top: 2px; text-shadow: 1px 1px 0 #000;">
								@upgrade.Description
							</div>

							@* ── Cumulative stat preview (tomes only) ── *@
							@if ( upgrade.StatPreview != null )
							{
								var parts = upgrade.StatPreview.Split( '→' );
								@if ( parts.Length == 2 )
								{
									<div style="font-size: 13px; font-family: Minecraft; display: flex; align-items: center; gap: 4px; padding-top: 2px; text-shadow: 1px 1px 0 #000;">
										<span style="color: #888870;">@parts[0].Trim()</span>
										<span style="color: #e8c060;">→</span>
										<span style="color: #88ee88; font-weight: bold;">@parts[1].Trim()</span>
									</div>
								}
							}

						</div>
						}
					</div>

					<!-- ── Action buttons ────────────────────────────────────── -->
					@if ( sys?.CanIgnore == true )
					{
						<div style="background: #1a1008; border: 2px solid #6a4a1a; border-radius: 4px; padding: 10px 32px; pointer-events: all; cursor: pointer; font-size: 15px; font-family: Minecraft; color: #a08050; font-weight: bold; letter-spacing: 2px; text-shadow: 1px 1px 0 #000;"
							 onclick=@(() => IgnoreOffers())>
							IGNORE OFFERS
						</div>
					}
					else if ( source == UpgradeSystem.RewardSource.LevelUp )
					{
						@if ( sys?.IsBanishMode == true )
						{
							<div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
								<div style="font-size: 13px; color: #ff4444; font-family: Minecraft; letter-spacing: 2px; text-shadow: 1px 1px 0 #000; font-weight: bold;">
									CLICK A CARD TO BANISH IT
								</div>
								<div class="upgrade-action-btn" style="border-color: #aa3333; color: #ff6666;"
									 onclick=@(() => CancelBanish())>
									<div class="upgrade-action-label">CANCEL</div>
								</div>
							</div>
						}
						else
						{
							@{
								var banishCount = sys?.BanishesRemaining ?? 0;
								var skipCount = sys?.SkipsRemaining ?? 0;
								var refreshCount = sys?.RefreshesRemaining ?? 0;
								var coins = PlayerCoins.LocalInstance;
								var canAffordRefresh = coins != null && coins.CanAfford( UpgradeSystem.RefreshCost );
								var banishDisabled = banishCount <= 0;
								var skipDisabled = skipCount <= 0;
								var refreshDisabled = refreshCount <= 0 || !canAffordRefresh;
							}
							<div style="display: flex; gap: 16px; justify-content: center; align-items: stretch;">
								<div class="upgrade-action-btn @(banishDisabled ? "disabled" : "")" style="border-color: #aa3333; color: #ff6666;"
									 onclick=@(() => ClickBanish())>
									<span style="font-size: 22px; font-weight: bold;">@banishCount</span>
									<span class="upgrade-action-label">BANISH</span>
								</div>
								<div class="upgrade-action-btn @(skipDisabled ? "disabled" : "")" style="border-color: #33aa33; color: #66ff66;"
									 onclick=@(() => ClickSkip())>
									<span style="font-size: 22px; font-weight: bold;">@skipCount</span>
									<span class="upgrade-action-label">SKIP</span>
								</div>
								<div class="upgrade-action-btn @(refreshDisabled ? "disabled" : "")" style="border-color: #3366cc; color: #6699ff;"
									 onclick=@(() => ClickRefresh())>
									<span style="font-size: 22px; font-weight: bold;">@refreshCount</span>
									<span class="upgrade-action-label">REFRESH</span>
									<span style="display: flex; align-items: center; gap: 4px; font-size: 10px; font-family: Minecraft; opacity: 0.7;">
										<img src="ui/coin.png" style="width: 14px; height: 14px; image-rendering: pixelated;" />
										@UpgradeSystem.RefreshCost
									</span>
								</div>
							</div>
						}
					}
					else
					{
						<div style="font-size: 11px; color: #5a3a10; font-family: Minecraft; letter-spacing: 3px; text-shadow: 1px 1px 0 #000;">
							CLICK A CARD TO SELECT
						</div>
					}

				</div>

				<!-- ══ RIGHT PANEL: Stats ═════════════════════════════════════ -->
				<div class="upgrade-side-panel">
					<div class="upgrade-panel-header">STATS</div>

					@if ( state != null )
					{
						<!-- Survivability -->
						<div class="upgrade-section-label">SURVIVABILITY</div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Max HP</span><span class="upgrade-stat-value">@((int)state.MaxHP)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">HP Regen</span><span class="upgrade-stat-value @(state.RegenPerMinute > 0 ? "highlight" : "")">@((int)state.RegenPerMinute)/min</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Shield</span><span class="upgrade-stat-value @(state.MaxShield > 0 ? "highlight" : "")">@((int)state.MaxShield)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Armor</span><span class="upgrade-stat-value @(state.Armor > 0 ? "highlight" : "")">@((int)state.Armor)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Evasion</span><span class="upgrade-stat-value @(state.Evasion > 0 ? "highlight" : "")">@Pct(state.Evasion)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Lifesteal</span><span class="upgrade-stat-value @(state.Lifesteal > 0 ? "highlight" : "")">@Pct(state.Lifesteal)</span></div>

						<!-- Offense -->
						<div class="upgrade-section-label">OFFENSE</div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Damage</span><span class="upgrade-stat-value">@(state.Damage.ToString("F1"))</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Crit Chance</span><span class="upgrade-stat-value">@Pct(state.CritChance)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Crit Dmg</span><span class="upgrade-stat-value">@Mult(state.CritMultiplier)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Attack Spd</span><span class="upgrade-stat-value @(state.CooldownMultiplier < 1f ? "highlight" : "")">@Pct(1f / state.CooldownMultiplier)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">+Proj</span><span class="upgrade-stat-value @(state.ProjectileCount > 0 ? "highlight" : "")">+@state.ProjectileCount</span></div>

						<!-- Utility -->
						<div class="upgrade-section-label">UTILITY</div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Area</span><span class="upgrade-stat-value">@Mult(state.Area)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Proj Speed</span><span class="upgrade-stat-value">@Mult(state.ProjectileSpeedMultiplier)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Duration</span><span class="upgrade-stat-value">@Mult(state.DurationMultiplier)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Knockback</span><span class="upgrade-stat-value">@Mult(state.Knockback)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Move Speed</span><span class="upgrade-stat-value">@((int)state.Speed)</span></div>

						<!-- Other -->
						<div class="upgrade-section-label">OTHER</div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Luck</span><span class="upgrade-stat-value @(state.Luck > 0 ? "highlight" : "")">@Pct(state.Luck)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Pickup Range</span><span class="upgrade-stat-value">@((int)state.MagnetRadius)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">XP Gain</span><span class="upgrade-stat-value @(state.XPMultiplier > 1f ? "highlight" : "")">@Mult(state.XPMultiplier)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Gold Gain</span><span class="upgrade-stat-value @(state.GoldMultiplier > 1f ? "highlight" : "")">@Mult(state.GoldMultiplier)</span></div>
						<div class="upgrade-stat-row"><span class="upgrade-stat-name">Silver Gain</span><span class="upgrade-stat-value @(state.SilverMultiplier > 1f ? "highlight" : "")">@Mult(state.SilverMultiplier)</span></div>
					}
				</div>

			</div>
		</div>
	}
</root>

@code
{
	static SoundEvent UiClick = new( "sounds/ui_click.mp3" );

	void PlayClickSound()
	{
		try { Sound.Play( UiClick ); } catch { }
	}

	UpgradeSystem UpgSys  => UpgradeSystem.LocalInstance;
	bool IsVisible        => UpgSys?.IsShowingUpgrades ?? false;

	void SelectUpgrade( int index )
	{
		PlayClickSound();
		UpgSys?.SelectUpgrade( index );
	}

	void IgnoreOffers()
	{
		PlayClickSound();
		UpgSys?.SelectIgnore();
	}

	void ClickBanish()  { PlayClickSound(); UpgSys?.EnterBanishMode(); }
	void CancelBanish() { PlayClickSound(); UpgSys?.CancelBanishMode(); }
	void ClickSkip()    { PlayClickSound(); UpgSys?.SkipLevelUp(); }
	void ClickRefresh() { PlayClickSound(); UpgSys?.RefreshChoices(); }

	// ── Title helpers per source ──────────────────────────────────────────────

	string TitleText( UpgradeSystem.RewardSource s ) => s switch
	{
		UpgradeSystem.RewardSource.LevelUp => "LEVEL UP!",
		UpgradeSystem.RewardSource.Shrine  => "CHARGE SHRINE",
		UpgradeSystem.RewardSource.Chest   => "CHEST REWARD",
		_                                  => "CHOOSE"
	};

	string SubtitleText( UpgradeSystem.RewardSource s ) => s switch
	{
		UpgradeSystem.RewardSource.LevelUp => "CHOOSE A TOME OR WEAPON",
		UpgradeSystem.RewardSource.Shrine  => "THE SHRINE OFFERS A REWARD",
		UpgradeSystem.RewardSource.Chest   => "CHOOSE AN ITEM",
		_                                  => "CHOOSE YOUR UPGRADE"
	};

	string TitleBg( UpgradeSystem.RewardSource s ) => s switch
	{
		UpgradeSystem.RewardSource.LevelUp => "#1a1008",
		UpgradeSystem.RewardSource.Shrine  => "#1a1408",
		UpgradeSystem.RewardSource.Chest   => "#140a1a",
		_                                  => "#1a1008"
	};

	string TitleBorder( UpgradeSystem.RewardSource s ) => s switch
	{
		UpgradeSystem.RewardSource.LevelUp => "#c8a800",
		UpgradeSystem.RewardSource.Shrine  => "#8a5a20",
		UpgradeSystem.RewardSource.Chest   => "#7755cc",
		_                                  => "#c8a800"
	};

	string TitleColor( UpgradeSystem.RewardSource s ) => s switch
	{
		UpgradeSystem.RewardSource.LevelUp => "#f5c518",
		UpgradeSystem.RewardSource.Shrine  => "#f5c518",
		UpgradeSystem.RewardSource.Chest   => "#cc99ff",
		_                                  => "#f5c518"
	};

	// ── Rarity helpers ────────────────────────────────────────────────────────

	string RarityBorderColor( UpgradeDefinition.UpgradeRarity r ) => r switch
	{
		UpgradeDefinition.UpgradeRarity.Common    => "#5a8a2a",
		UpgradeDefinition.UpgradeRarity.Uncommon  => "#8a6a20",
		UpgradeDefinition.UpgradeRarity.Rare      => "#8a4a8a",
		UpgradeDefinition.UpgradeRarity.Legendary => "#b87820",
		_                                         => "#6a5a4a"
	};

	string RarityBg( UpgradeDefinition.UpgradeRarity r ) => r switch
	{
		UpgradeDefinition.UpgradeRarity.Common    => "#0d1408",
		UpgradeDefinition.UpgradeRarity.Uncommon  => "#1a1408",
		UpgradeDefinition.UpgradeRarity.Rare      => "#1a0818",
		UpgradeDefinition.UpgradeRarity.Legendary => "#1a1200",
		_                                         => "#111108"
	};

	string RarityBadgeBg( UpgradeDefinition.UpgradeRarity r ) => r switch
	{
		UpgradeDefinition.UpgradeRarity.Common    => "#0d1a0a",
		UpgradeDefinition.UpgradeRarity.Uncommon  => "#1a1404",
		UpgradeDefinition.UpgradeRarity.Rare      => "#1a0a18",
		UpgradeDefinition.UpgradeRarity.Legendary => "#1a1000",
		_                                         => "#111108"
	};

	string RarityTextColor( UpgradeDefinition.UpgradeRarity r ) => r switch
	{
		UpgradeDefinition.UpgradeRarity.Common    => "#88cc66",
		UpgradeDefinition.UpgradeRarity.Uncommon  => "#e8c060",
		UpgradeDefinition.UpgradeRarity.Rare      => "#dd88dd",
