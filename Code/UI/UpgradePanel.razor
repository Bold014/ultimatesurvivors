		"Lodestone Ring"      => "ui/tomes/xp.png",
		"Quick Heal Potion"   => "ui/tomes/regen.png",
		_                     => null
	};

	static string TomeIconPath( string tomeName )
	{
		var key = (tomeName ?? "").ToLowerInvariant().Replace( " ", "" );
		return key switch
		{
			"agility" or "agilitytome" => "ui/tomes/agility.png",
			"size" or "sizetome" => "ui/tomes/size.png",
			"shield" or "shieldtome" => "ui/tomes/shield.png",
			"regen" or "regentome" => "ui/tomes/regen.png",
			"lifesteal" or "lifestealtome" => "ui/tomes/lifesteal.png",
			"projectilespeed" or "projectilespeedtome" => "ui/tomes/projectilespeed.png",
			"hp" or "hptome" => "ui/tomes/hp.png",
			"golden" or "goldentome" => "ui/tomes/golden.png",
			"damage" or "damagetome" => "ui/tomes/damage.png",
			"cooldown" or "cooldowntome" => "ui/tomes/cooldown.png",
			"precision" or "precisiontome" => "ui/tomes/precision.png",
			"knockback" or "knockbacktome" => "ui/tomes/knockback.png",
			"quantity" or "quantitytome" => "ui/tomes/quantity.png",
			"duration" or "durationtome" => "ui/tomes/duration.png",
			"xp" or "xptome" => "ui/tomes/xp.png",
			_ => null
		};
	}

