	private bool _lastVisible = false;
	private float _showStartTime = -1f;

	string GemStyle( GemParticle p )
	{
		float elapsed = Time.Now - _showStartTime;
		float loopDur = p.Dur;
		float t = ((elapsed - p.Delay) % loopDur + loopDur) % loopDur;

		float x   = p.X0 + p.VX * t;
		float y   = p.Y0 + p.VY * t;
		float rot = (p.AngVel * t) % 360f;

		float tNorm  = t / loopDur;
		float opacity = tNorm < 0.15f ? tNorm / 0.15f
		              : tNorm > 0.85f ? (1f - tNorm) / 0.15f
		              : 1f;

		return $"position:absolute; left:{x:F1}%; top:{y:F1}%; opacity:{opacity:F2}; transform:rotate({rot:F0}deg); width:{p.Size}px; height:{p.Size}px; pointer-events:none; image-rendering:pixelated;";
	}

	protected override int BuildHash()
	{
		var sys = UpgSys;
		var s = PlayerLocalState.LocalInstance;
		bool showing = sys?.IsShowingUpgrades ?? false;

		if ( showing && !_lastVisible )
			_showStartTime = Time.Now;

		if ( showing != _lastVisible )
		{
			_lastVisible = showing;
			Log.Info( $"[UpgradePanel] BuildHash — IsShowingUpgrades changed to {showing}. UpgSys={(sys != null ? "SET" : "NULL")}. Choices={sys?.CurrentChoices?.Count ?? -1}" );
		}

		var coins = PlayerCoins.LocalInstance;
		return System.HashCode.Combine(
			showing,
			sys?.CurrentChoices?.Count ?? 0,
			(int)(sys?.CurrentSource ?? 0),
			System.HashCode.Combine(
				(int)(s?.MaxHP ?? 0),
				(int)(s?.Damage * 10 ?? 0),
				sys?.BanishesRemaining ?? 0,
				sys?.SkipsRemaining ?? 0,
				sys?.RefreshesRemaining ?? 0,
				sys?.IsBanishMode ?? false,
				coins?.Coins ?? 0
			),
			showing ? (int)((Time.Now - _showStartTime) * 30f) : 0
		);
	}
