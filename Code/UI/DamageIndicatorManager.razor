@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
	<div class="dmg-overlay">
		@foreach ( var ind in Indicators )
		{
			<div class="dmg-number @ind.SizeClass" style="left: @ind.ScreenX%; top: @ind.ScreenY%; opacity: @ind.Opacity; color: @ind.TextColor;">@(ind.DisplayText)</div>
		}
	</div>
</root>

@code
{
	public static DamageIndicatorManager Instance { get; private set; }

	private const float Lifetime = 0.85f;
	private const float FloatSpeedPct = 15f; // % of screen per second (always visible, no world dependency)

	protected override void OnStart()
	{
		Instance = this;
	}

	protected override void OnDestroy()
	{
		if ( Instance == this )
			Instance = null;
	}

	protected override void OnUpdate()
	{
		float dt = Time.Delta;
		foreach ( var ind in Indicators )
		{
			ind.Elapsed += dt;
			ind.ScreenY -= FloatSpeedPct * dt; // Float up in screen space
		}
		Indicators.RemoveAll( ind => ind.Elapsed >= Lifetime );
	}

	public void RequestIndicator( Vector3 worldPos, float amount, bool isCritical )
	{
		float xJitter = (System.Random.Shared.NextSingle() - 0.5f) * 8f;
		Indicators.Add( new IndicatorData( amount, isCritical, xJitter ) );
	}

	private List<IndicatorData> Indicators { get; } = new();
	private int _rebuildTick;

	protected override int BuildHash()
	{
		if ( Indicators.Count > 0 )
			_rebuildTick++;
		return System.HashCode.Combine( Indicators.Count, _rebuildTick );
	}

	private class IndicatorData
	{
		public float Damage { get; }
		public bool IsCritical { get; }
		public float Elapsed { get; set; }
		public float ScreenX { get; }
		public float ScreenY { get; set; }

		public IndicatorData( float damage, bool isCritical, float xJitter )
		{
			Damage = damage;
			IsCritical = isCritical;
			ScreenX = 50f + xJitter; // Center of screen with slight horizontal jitter
			ScreenY = 65f; // Start near bottom-center (always on screen)
		}

		public float Opacity => Math.Clamp( 1f - (Elapsed / Lifetime), 0f, 1f );
		public string DisplayText => IsCritical
			? $"CRIT {(int)MathF.Ceiling( Damage )}!"
			: ((int)MathF.Ceiling( Damage )).ToString();
		public string SizeClass => (IsCritical || Damage >= 30f) ? "big" : "normal";
		public string TextColor => IsCritical
			? "rgb(255, 50, 50)"
			: (Damage >= 50f ? "rgb(255,110,20)" : "rgb(255,220,55)");
	}
}
