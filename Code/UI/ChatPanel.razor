@using Sandbox;
@inherits PanelComponent;

<root>
	<div style="position: absolute; bottom: 60px; left: 14px; width: 380px; max-width: 90%;">

		<div style="display: flex; flex-direction: column; gap: 3px; margin-bottom: 8px;">
			@if ( Chat != null )
			{
				@foreach ( var msg in Chat.Messages.TakeLast( 8 ) )
				{
					var isSystem = msg.PlayerName == "System";
					<div style="display: flex; flex-wrap: wrap; align-items: baseline; font-size: 13px; font-family: Minecraft; background: @(isSystem ? "#1a1410" : "#0f0d0a"); padding: 4px 10px; border-radius: 4px; border-left: 3px solid @(isSystem ? "#c8a800" : "transparent");">
						<span style="color: @ColorToHex( msg.NameColor ); flex-shrink: 0; white-space: nowrap;">@msg.PlayerName</span>
						<span style="color: #dddddd; margin-left: 4px;">: @msg.Text</span>
					</div>
				}
			}
		</div>

		@if ( Chat?.IsChatOpen == true )
		{
			<div style="background: #0a0806; border: 2px solid #4a3520; border-radius: 6px; padding: 6px 10px;">
				<TextEntry style="color: #ffffff; font-size: 13px; font-family: Minecraft; width: 100%;"
					placeholder="Type a message and press Enter..."
					onsubmit=@OnSubmit />
			</div>
		}
		else
		{
			<div style="font-size: 11px; color: #6a5a40; font-family: Minecraft;">[Enter] to chat</div>
		}
	</div>
</root>

@code
{
	ChatComponent Chat => ChatComponent.Instance;

	void OnSubmit( PanelEvent e )
	{
		if ( Chat == null ) return;
		if ( e.Target is TextEntry te )
			Chat.CurrentInput = te.Text ?? "";
		Chat.Submit();
	}

	string ColorToHex( Color c )
	{
		int r = (int)(c.r * 255);
		int g = (int)(c.g * 255);
		int b = (int)(c.b * 255);
		return $"#{r:X2}{g:X2}{b:X2}";
	}

	protected override int BuildHash() =>
		System.HashCode.Combine(
			Chat?.Messages?.Count ?? 0,
			Chat?.IsChatOpen ?? false
		);
}
